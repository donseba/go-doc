{
  "name": "go-doc-vscode",
  "displayName": "go-doc",
  "description": "Template contract completion and diagnostics for Go template files.",
  "version": "0.8.27",
  "publisher": "donseba",
  "author": {
    "name": "Sebastiano Bellinzis",
    "email": "sebastiano.bellinzis@outlook.com",
    "url": "https://github.com/donseba"
  },
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/donseba/go-doc"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "files": [
    "extension.js",
    "icon.png",
    "language-configuration.json",
    "LICENSE",
    "README.md",
    "package.json",
    "node_modules/**"
  ],
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:go-template",
    "onLanguage:go-html-template",
    "onLanguage:gotmpl",
    "onLanguage:html",
    "onStartupFinished",
    "workspaceContains:**/*.gohtml",
    "workspaceContains:**/*.tmpl",
    "onCommand:goDoc.rebuildIndex",
    "onCommand:goDoc.showIndexStatus",
    "onCommand:goDoc.toggleAutoIndex",
    "onCommand:goDoc.restartLsp"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "go-template",
        "aliases": [
          "Go Template",
          "go-template"
        ],
        "extensions": [
          ".gohtml",
          ".tmpl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "commands": [
      {
        "command": "goDoc.rebuildIndex",
        "title": "go-doc: Rebuild Index"
      },
      {
        "command": "goDoc.showIndexStatus",
        "title": "go-doc: Show Index Status"
      },
      {
        "command": "goDoc.toggleAutoIndex",
        "title": "go-doc: Toggle Auto Index"
      },
      {
        "command": "goDoc.restartLsp",
        "title": "go-doc: Restart LSP"
      }
    ],
    "configurationDefaults": {
      "[go-template]": {
        "editor.semanticHighlighting.enabled": true
      },
      "[go-html-template]": {
        "editor.semanticHighlighting.enabled": true
      },
      "[gotmpl]": {
        "editor.semanticHighlighting.enabled": true
      },
      "editor.semanticTokenColorCustomizations": {
        "rules": {
          "variable:go-template": "#DCDCAA",
          "property:go-template": "#9CDCFE",
          "type:go-template": "#4EC9B0",
          "variable:go-html-template": "#DCDCAA",
          "property:go-html-template": "#9CDCFE",
          "type:go-html-template": "#4EC9B0",
          "variable:gotmpl": "#DCDCAA",
          "property:gotmpl": "#9CDCFE",
          "type:gotmpl": "#4EC9B0"
        }
      }
    },
    "configuration": {
      "title": "go-doc",
      "properties": {
        "goDoc.autoIndex": {
          "type": "boolean",
          "default": true,
          "description": "Automatically rebuild .go-doc/index.json after Go or template files change."
        },
        "goDoc.debounceMilliseconds": {
          "type": "number",
          "default": 1200,
          "minimum": 250,
          "description": "Delay before automatic index rebuilds after file changes."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
