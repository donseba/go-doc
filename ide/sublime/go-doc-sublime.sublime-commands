[
  {
    "caption": "Preferences: go-doc Settings",
    "command": "edit_settings",
    "args": {
      "base_file": "${packages}/go-doc-sublime/go-doc-sublime.sublime-settings",
      "default": "// Settings in here override those in \"go-doc-sublime/go-doc-sublime.sublime-settings\"\n\n{\n\t$0\n}\n"
    }
  },
  {
    "caption": "go-doc: Open README",
    "command": "open_file",
    "args": {
      "file": "${packages}/go-doc-sublime/README.md"
    }
  }
]
