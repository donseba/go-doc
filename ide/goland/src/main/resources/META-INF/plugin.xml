<idea-plugin>
    <id>com.donseba.godoc</id>
    <name>go-doc</name>
    <vendor email="sebastiano.bellinzis@outlook.com" url="https://github.com/donseba/go-doc">Sebastiano Bellinzis</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>com.intellij.modules.lsp</depends>
    <depends>com.intellij.modules.ultimate</depends>
    <depends>org.jetbrains.plugins.go-template</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="go-doc" displayType="BALLOON"/>
        <platform.lsp.serverSupportProvider implementation="com.donseba.godoc.GoDocLspServerSupportProvider"/>
        <psi.referenceContributor implementation="com.donseba.godoc.GoDocReferenceContributor"/>
        <gotoDeclarationHandler implementation="com.donseba.godoc.GoDocGotoDeclarationHandler"/>
        <documentationProvider implementation="com.donseba.godoc.GoDocDocumentationProvider"/>
        <postStartupActivity implementation="com.donseba.godoc.GoDocStartupActivity"/>
    </extensions>

    <actions>
        <action id="GoDoc.RebuildIndex"
                class="com.donseba.godoc.RebuildIndexAction"
                text="Rebuild go-doc Index"
                description="Regenerate .go-doc/index.json for this project">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="GoDoc.ShowIndexStatus"
                class="com.donseba.godoc.ShowIndexStatusAction"
                text="Show go-doc Index Status"
                description="Show which generated go-doc index this project is using">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="GoDoc.ToggleAutoIndex"
                class="com.donseba.godoc.ToggleAutoIndexAction"
                text="go-doc Auto Index"
                description="Enable or disable automatic go-doc index rebuilding for this project">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
